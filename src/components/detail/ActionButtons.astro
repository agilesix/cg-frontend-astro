---
import { getByPath } from '@/lib/format';

interface Props {
  opportunity: unknown;
}

const { opportunity } = Astro.props;

const sourceUrl =
  (getByPath(opportunity, 'customFields.additionalInfo.value.url') as string | undefined) ??
  (getByPath(opportunity, 'source') as string | undefined) ??
  (getByPath(opportunity, 'customFields.paSlug.value') as string | undefined);

interface Attachment {
  name?: string;
  downloadUrl?: string;
  title?: string;
  url?: string;
}
const attachments = (
  (getByPath(opportunity, 'customFields.attachments.value') as Attachment[] | undefined) ??
  (getByPath(opportunity, 'customFields.paAdditionalResources.value') as Attachment[] | undefined) ??
  []
)
  .map((att) => ({ href: att.downloadUrl ?? att.url, label: att.name ?? att.title ?? 'Attachment' }))
  .filter((a): a is { href: string; label: string } => Boolean(a.href));
---

{
  (sourceUrl || attachments.length > 0) && (
    <section class="actions">
      {sourceUrl && (
        <a class="usa-button apply-button" href={sourceUrl} target="_blank" rel="noopener noreferrer">
          Apply at source
          <svg class="ext-icon" aria-hidden="true" viewBox="0 0 24 24" focusable="false">
            <path d="M14 3h7v7m0-7L10 14M19 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h5" />
          </svg>
        </a>
      )}

      {attachments.length > 0 && (
        <div class="attachments">
          <h2 class="attachments__heading">Documents &amp; resources</h2>
          <ul class="attachments__list">
            {attachments.map((att) => (
              <li>
                <a class="attachment" href={att.href} target="_blank" rel="noopener noreferrer">
                  <svg class="file-icon" aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <path d="M14 2v6h6" />
                  </svg>
                  <span class="attachment__name">{att.label}</span>
                  <svg class="ext-icon" aria-hidden="true" viewBox="0 0 24 24" focusable="false">
                    <path d="M14 3h7v7m0-7L10 14M19 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h5" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )
}

<style>
  .actions {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 2rem 0;
  }

  /* Primary CTA: sized to its content, not stretched across the row. */
  .apply-button {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .attachments__heading {
    font-size: 1rem;
    margin: 0 0 0.5rem;
  }
  .attachments__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid #dfe1e2;
    border-radius: 0.25rem;
  }
  .attachments__list li + li {
    border-top: 1px solid #dfe1e2;
  }

  .attachment {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    color: #005ea2;
    text-decoration: none;
  }
  .attachment:hover,
  .attachment:focus {
    background-color: #f0f0f0;
    text-decoration: underline;
  }
  .attachment__name {
    flex: 1;
    min-width: 0;
    word-break: break-word;
  }

  .file-icon,
  .ext-icon {
    flex-shrink: 0;
    width: 1.125rem;
    height: 1.125rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .file-icon {
    color: #71767a;
  }
</style>
</content>
