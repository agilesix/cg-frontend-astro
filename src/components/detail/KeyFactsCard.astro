---
import { getByPath, formatDate, formatCurrency } from '@/lib/format';
import type { KeyFactConfig, KeyFactsCardConfig } from '@/types/portal';

interface Props {
  card: KeyFactsCardConfig;
  opportunity: unknown;
}

const { card, opportunity } = Astro.props;

function inferFormat(path: string): NonNullable<KeyFactConfig['format']> {
  if (path.includes('Amount')) return 'currency';
  if (path.includes('Date')) return 'date';
  return 'text';
}

function renderValue(fact: KeyFactConfig): string | null {
  const raw = getByPath(opportunity, fact.fieldPath);
  if (raw == null) return null;

  switch (fact.format ?? inferFormat(fact.fieldPath)) {
    case 'date':
      return formatDate(raw);
    case 'currency':
      return formatCurrency(raw);
    case 'boolean':
      return raw ? 'Yes' : 'No';
    default:
      if (typeof raw === 'boolean') return raw ? 'Yes' : 'No';
      if (typeof raw === 'number' || typeof raw === 'string') return String(raw);
      return null;
  }
}

const rows = card.facts
  .map((f) => ({ term: f.term, value: renderValue(f), hint: f.hint }))
  .filter((r) => r.value != null);
---

{
  rows.length > 0 && (
    <div class="usa-card">
      <div class="usa-card__container">
        <header class="usa-card__header">
          <h2 class="usa-card__heading">{card.heading}</h2>
        </header>
        <div class="usa-card__body">
          <dl>
            {rows.map((r) => (
              <div class="fact-row">
                <dt>{r.term}</dt>
                <dd>
                  <span class="fact-value">
                    {r.value}
                    {r.hint && <span class="usa-hint"> — {r.hint}</span>}
                  </span>
                  <button type="button" class="fact-toggle" hidden>
                    Show more
                  </button>
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  )
}

<style>
  .fact-row {
    display: grid;
    grid-template-columns: minmax(9rem, 1fr) 2fr;
    gap: 0.5rem;
    padding: 0.25rem 0;
    border-bottom: 1px solid #dfe1e2;
  }
  .fact-row:last-child {
    border-bottom: 0;
  }
  dt {
    font-weight: 600;
    color: #565c65;
  }
  dd {
    margin: 0;
  }
  /* Clamp long values to 2 lines; the toggle (revealed by the script only
     when the text actually overflows) expands them. */
  .fact-value {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }
  .fact-value.is-expanded {
    display: block;
    -webkit-line-clamp: unset;
    line-clamp: unset;
    overflow: visible;
  }
  .fact-toggle {
    background: none;
    border: 0;
    color: #005ea2;
    cursor: pointer;
    font-size: 0.875rem;
    padding: 0.125rem 0;
  }
  .fact-toggle:hover {
    text-decoration: underline;
  }
</style>

<script>
  // Reveal the "Show more" toggle only for values that are actually clamped
  // (text taller than the 2-line box), then let it expand/collapse.
  function initFactToggles() {
    document.querySelectorAll<HTMLElement>('.fact-row').forEach((row) => {
      const value = row.querySelector<HTMLElement>('.fact-value');
      const toggle = row.querySelector<HTMLButtonElement>('.fact-toggle');
      if (!value || !toggle || toggle.dataset.ready) return;
      if (value.scrollHeight - value.clientHeight > 1) {
        toggle.hidden = false;
        toggle.dataset.ready = 'true';
        toggle.addEventListener('click', () => {
          const expanded = value.classList.toggle('is-expanded');
          toggle.textContent = expanded ? 'Show less' : 'Show more';
        });
      }
    });
  }
  initFactToggles();
  // Re-run after view transitions / client navigations.
  document.addEventListener('astro:page-load', initFactToggles);
</script>
