---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="usa-section">
    <div class="grid-container">
      <h1>Search grant opportunities</h1>
      <p class="usa-intro">
        Find funding from Pennsylvania state agencies and federal Grants.gov in one place. All
        results are standardized via the CommonGrants protocol.
      </p>
      <a href="/search" class="usa-button usa-button--big">Search opportunities</a>
    </div>
  </section>
</BaseLayout>
