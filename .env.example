# --------------- Public — inlined into the build at build time ---------------
# `PUBLIC_` prefix → Vite inlines into both client and server bundles via
# `import.meta.env.X`. URLs are not secrets, so keeping them here means
# they're available everywhere without per-environment Worker var setup.

PUBLIC_PA_API_URL=http://localhost:8787
PUBLIC_FEDERAL_API_URL=https://api.simpler.grants.gov

# --------------- Server-only — runtime via `process.env` ---------------------
# No `PUBLIC_` prefix, accessed via `process.env.X` (NOT `import.meta.env.X`)
# so the value resolves at runtime and is never inlined into a build artifact.
#
#   - In `astro dev`, Astro/Vite populates `process.env` from `.env.local`
#     when the dev server starts.
#   - In Cloudflare Workers production, set with:
#       wrangler secret put FEDERAL_API_TOKEN
#     The Workers runtime (with `nodejs_compat`) binds it to `process.env`.

FEDERAL_API_TOKEN=
