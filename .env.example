# Source API URLs. `PUBLIC_` prefix is required so these are available to
# Svelte islands running in the browser (Astro's env convention).
PUBLIC_PA_API_URL=http://localhost:8787
PUBLIC_FEDERAL_API_URL=https://api.simpler.grants.gov

# api.simpler.grants.gov requires an API key sent in the X-API-Key header.
# Request one from the Simpler Grants.gov team. With this set, the SDK client
# adds the header automatically via Auth.apiKey().
PUBLIC_FEDERAL_API_TOKEN=
