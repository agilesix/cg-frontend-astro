{
  "name": "@common-grants/astro-portal",
  "version": "0.1.0",
  "description": "Astro frontend for federated CommonGrants search across PA state and federal opportunities",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "node scripts/copy-uswds-assets.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "wrangler deploy --config dist/server/wrangler.json",
    "astro": "astro",
    "copy-assets": "node scripts/copy-uswds-assets.mjs",
    "lint": "eslint . --fix",
    "check:lint": "eslint .",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "check:types": "astro check && tsc --noEmit",
    "checks": "pnpm run check:lint && pnpm run check:format && pnpm run check:types",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "ci": "pnpm run checks && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.0",
    "@astrojs/svelte": "^8.0.0",
    "@common-grants/cg-grants-gov": "^0.1.0",
    "@common-grants/sdk": "^0.4.0",
    "@nanostores/persistent": "^1.3.3",
    "@uswds/uswds": "^3.13.0",
    "astro": "^6.1.8",
    "nanostores": "^1.0.1",
    "svelte": "^5.40.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.5.0",
    "happy-dom": "^18.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte-check": "^4.4.0",
    "svelte-eslint-parser": "^1.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
