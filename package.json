{
  "name": "@common-grants/astro-portal",
  "version": "0.1.0",
  "description": "Astro frontend for federated CommonGrants search across PA state and federal opportunities",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "node scripts/copy-uswds-assets.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "wrangler deploy --config dist/server/wrangler.json",
    "astro": "astro",
    "copy-assets": "node scripts/copy-uswds-assets.mjs",
    "lint": "eslint . --fix",
    "check:lint": "eslint .",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "check:types": "astro check && tsc --noEmit",
    "checks": "pnpm run check:lint && pnpm run check:format && pnpm run check:types",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "ci": "pnpm run checks && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/svelte": "^8.1.2",
    "@common-grants/cg-grants-gov": "^0.1.0",
    "@common-grants/sdk": "^0.4.1",
    "@nanostores/persistent": "^1.3.4",
    "@uswds/uswds": "^3.13.0",
    "astro": "^6.4.8",
    "nanostores": "^1.3.0",
    "svelte": "^5.56.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.28.1": "^0.28.1",
      "yaml@<2.8.3": "^2.8.3"
    }
  }
}
